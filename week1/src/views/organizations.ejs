<%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        
        <p>Here are a few of our partner organizations:</p>
        <ul>

            <% organizations.forEach(organization => { %>
                <li>
                    <img src="/images/<%= organization.logo_filename %>" alt="<%= organization.name %> logo">
                    <a href="/organization/<%= organization.organization_id %>"><strong><%= organization.name %></strong></a>
                    <%= organization.description %>
                    <a href="mailto:<%= organization.contact_email %>"><%= organization.contact_email %></a>
                </li>
            <% }); %>
        </ul>
    </main>
<%- include('partials/footer') %>
