<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= categoryDetails.name %></h2>
    <p><a href="/edit-category/<%= categoryDetails.category_id %>">Edit Category</a></p>

    <h3>Service Projects</h3>
    <ul>
        <% projects.forEach(project => { %>
            <li>
                <a href="/project/<%= project.project_id %>"><%= project.title %></a>
                (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
            </li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>
