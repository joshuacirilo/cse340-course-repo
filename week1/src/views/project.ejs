<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= projectDetails.title %></h2>
    <p><%= projectDetails.description %></p>
    <p>Date: <%= projectDetails.date.toLocaleDateString('en-US') %></p>
    <p>Location: <%= projectDetails.location %></p>
    <p>
        Partner Organization:
        <a href="/organization/<%= projectDetails.organization_id %>"><%= projectDetails.organization_name %></a>
    </p>

    <h3>Categories</h3>
    <p><a href="/assign-categories/<%= projectDetails.project_id %>">Edit Categories</a></p>
    <ul>
        <% categories.forEach(category => { %>
            <li><a href="/category/<%= category.category_id %>"><%= category.name %></a></li>
        <% }); %>
    </ul>
</main>
<%- include('partials/footer') %>
